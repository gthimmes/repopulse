.DS_Store

# Node — Playwright harness only
node_modules/

# Go
tools/go/
bin/
mood-ring.exe
mood-ring
fixture-gen.exe
fixture-gen
*.test

# E2E test output
test-results/
playwright-report/
tests/screenshots/*.png
tests/screenshots/*.html
